<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="petroraq_our_clients" name="PETRORAQ Our Clients">
            <t t-call="website.layout">
                <t t-set="additional_title">Our Clients - PETRORAQ</t>

                <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&amp;display=swap"
                      rel="stylesheet"/>

                <style>
                    .petroraq-clients * {
                    margin: 0;
                    padding: 0;
                    box-sizing: border-box;
                    font-family: 'Poppins', sans-serif;
                    }
                    .petroraq-clients {
                    background: #ffffff;
                    color: #0a2540;
                    }
                    .petroraq-clients .pr-container {
                    max-width: 1200px;
                    margin: 0 auto;
                    padding: 0 20px;
                    }

                    /* ===== Hero Section ===== */
                    .petroraq-clients .clients-hero {
                    position: relative;
                    min-height: 280px;
                    background: url('https://images.unsplash.com/photo-1518709268805-4e9042af2176?w=1600&amp;q=80')
                    right center/cover no-repeat;
                    overflow: hidden;
                    display: flex;
                    align-items: center;
                    }
                    .petroraq-clients .hero-overlay {
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(90deg, #ffffff 0%, rgba(255,255,255,0.92) 30%, rgba(255,255,255,0.6)
                    50%, rgba(255,255,255,0) 70%);
                    }
                    .petroraq-clients .hero-content {
                    position: relative;
                    z-index: 2;
                    padding: 60px 60px;
                    max-width: 550px;
                    }
                    .petroraq-clients .hero-content h1 {
                    font-size: 54px;
                    font-weight: 700;
                    color: #0a2540;
                    margin-bottom: 18px;
                    line-height: 1;
                    }
                    .petroraq-clients .hero-content h1 .dot {
                    color: #d89a2b;
                    }
                    .petroraq-clients .hero-content p {
                    font-size: 14px;
                    line-height: 1.7;
                    color: #4a5568;
                    margin-bottom: 20px;
                    max-width: 360px;
                    }
                    .petroraq-clients .hero-accent {
                    width: 70px;
                    height: 3px;
                    background: #d89a2b;
                    }

                    /* ===== Partnerships Section ===== */
                    .petroraq-clients .partnerships-section {
                    padding: 55px 0 40px;
                    }
                    .petroraq-clients .partnerships-grid {
                    display: grid;
                    grid-template-columns: 1fr 1fr 1fr 1fr;
                    gap: 18px;
                    align-items: stretch;
                    }
                    .petroraq-clients .partnership-text h2 {
                    font-size: 19px;
                    font-weight: 700;
                    color: #0a2540;
                    margin-bottom: 14px;
                    line-height: 1.3;
                    }
                    .petroraq-clients .partnership-text p {
                    font-size: 13px;
                    color: #6b7a8f;
                    line-height: 1.7;
                    }
                    .petroraq-clients .partnership-card {
                    background: #fff;
                    border: 1px solid #e5e8ec;
                    border-radius: 10px;
                    padding: 22px 20px;
                    display: flex;
                    align-items: center;
                    gap: 16px;
                    transition: transform 0.3s, box-shadow 0.3s;
                    }
                    .petroraq-clients .partnership-card:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 8px 18px rgba(0,0,0,0.05);
                    }
                    .petroraq-clients .pc-icon {
                    width: 55px;
                    height: 55px;
                    background: #fff;
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    flex-shrink: 0;
                    }
                    .petroraq-clients .pc-icon i {
                    color: #d89a2b;
                    font-size: 30px;
                    }
                    .petroraq-clients .pc-content h3 {
                    font-size: 22px;
                    font-weight: 700;
                    color: #0a2540;
                    margin-bottom: 2px;
                    line-height: 1.1;
                    }
                    .petroraq-clients .pc-content h4 {
                    font-size: 13px;
                    font-weight: 600;
                    color: #0a2540;
                    margin-bottom: 6px;
                    line-height: 1.3;
                    }
                    .petroraq-clients .pc-content p {
                    font-size: 11px;
                    color: #6b7a8f;
                    line-height: 1.5;
                    }

                    /* ===== Organizations We Work With ===== */
                    .petroraq-clients .orgs-section {
                    padding: 25px 0 40px;
                    }
                    .petroraq-clients .section-title {
                    text-align: center;
                    font-size: 22px;
                    font-weight: 700;
                    color: #0a2540;
                    margin-bottom: 35px;
                    position: relative;
                    padding-bottom: 10px;
                    }
                    .petroraq-clients .section-title::after {
                    content: '';
                    position: absolute;
                    left: 50%;
                    bottom: 0;
                    transform: translateX(-50%);
                    width: 60px;
                    height: 2px;
                    background: #d89a2b;
                    }
                    .petroraq-clients .orgs-grid {
                    display: grid;
                    grid-template-columns: repeat(4, 1fr);
                    gap: 18px;
                    }
                    .petroraq-clients .org-card {
                    background: #fff;
                    border: 1px solid #e5e8ec;
                    border-radius: 10px;
                    height: 120px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    padding: 20px;
                    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
                    }
                    .petroraq-clients .org-card:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 8px 20px rgba(0,0,0,0.06);
                    border-color: #d89a2b;
                    }
                    .petroraq-clients .org-card img {
                    max-width: 100%;
                    max-height: 70px;
                    object-fit: contain;
                    filter: grayscale(0%);
                    transition: filter 0.3s;
                    }

                    /* ===== Why Leading Clients Choose PETRORAQ ===== */
                    .petroraq-clients .why-section {
                    padding: 40px 0;
                    }
                    .petroraq-clients .why-grid {
                    display: grid;
                    grid-template-columns: repeat(4, 1fr);
                    gap: 18px;
                    }
                    .petroraq-clients .why-card {
                    background: #fff;
                    border: 1px solid #e5e8ec;
                    border-radius: 10px;
                    padding: 28px 20px;
                    text-align: center;
                    transition: transform 0.3s, box-shadow 0.3s;
                    }
                    .petroraq-clients .why-card:hover {
                    transform: translateY(-4px);
                    box-shadow: 0 8px 20px rgba(0,0,0,0.06);
                    }
                    .petroraq-clients .why-icon {
                    font-size: 40px;
                    color: #d89a2b;
                    margin-bottom: 15px;
                    }
                    .petroraq-clients .why-card h4 {
                    font-size: 15px;
                    font-weight: 700;
                    color: #0a2540;
                    margin-bottom: 10px;
                    }
                    .petroraq-clients .why-card p {
                    font-size: 12px;
                    color: #6b7a8f;
                    line-height: 1.6;
                    }

                    /* ===== CTA Banner ===== */
                    .petroraq-clients .cta-section {
                    padding: 30px 0 50px;
                    }
                    .petroraq-clients .cta-banner {
                    background: #0a2540;
                    background-image:
                    radial-gradient(circle at 90% 50%, rgba(216,154,43,0.08) 0%, transparent 50%),
                    linear-gradient(135deg, #0a2540 0%, #071a2f 100%);
                    border: 1px solid rgba(216,154,43,0.25);
                    border-radius: 12px;
                    padding: 28px 40px;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    flex-wrap: wrap;
                    gap: 25px;
                    }
                    .petroraq-clients .cta-left {
                    display: flex;
                    align-items: center;
                    gap: 20px;
                    }
                    .petroraq-clients .hex-icon {
                    width: 58px;
                    height: 58px;
                    background: transparent;
                    border: 2px solid #d89a2b;
                    clip-path: polygon(25% 5%, 75% 5%, 100% 50%, 75% 95%, 25% 95%, 0% 50%);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    flex-shrink: 0;
                    }
                    .petroraq-clients .hex-icon i {
                    color: #d89a2b;
                    font-size: 22px;
                    }
                    .petroraq-clients .cta-text h3 {
                    color: #fff;
                    font-size: 20px;
                    font-weight: 700;
                    margin-bottom: 3px;
                    }
                    .petroraq-clients .cta-text p {
                    color: #b8c5d6;
                    font-size: 13px;
                    }
                    .petroraq-clients .cta-buttons {
                    display: flex;
                    gap: 12px;
                    }
                    .petroraq-clients .btn-cta-primary,
                    .petroraq-clients .btn-cta-outline {
                    padding: 12px 26px;
                    border-radius: 6px;
                    font-size: 13px;
                    font-weight: 600;
                    text-decoration: none;
                    display: inline-flex;
                    align-items: center;
                    gap: 10px;
                    transition: all 0.3s;
                    }
                    .petroraq-clients .btn-cta-primary {
                    background: #d89a2b;
                    color: #fff;
                    }
                    .petroraq-clients .btn-cta-primary:hover {
                    background: #e5a838;
                    color: #fff;
                    transform: translateY(-2px);
                    }
                    .petroraq-clients .btn-cta-outline {
                    background: transparent;
                    color: #fff;
                    border: 1px solid rgba(255,255,255,0.3);
                    }
                    .petroraq-clients .btn-cta-outline:hover {
                    background: rgba(255,255,255,0.08);
                    color: #fff;
                    }

                    /* ===== Responsive ===== */
                    @media (max-width: 992px) {
                    .petroraq-clients .hero-content { padding: 40px 30px; }
                    .petroraq-clients .hero-content h1 { font-size: 42px; }
                    .petroraq-clients .partnerships-grid { grid-template-columns: 1fr 1fr; }
                    .petroraq-clients .orgs-grid { grid-template-columns: repeat(3, 1fr); }
                    .petroraq-clients .why-grid { grid-template-columns: repeat(2, 1fr); }
                    }
                    @media (max-width: 600px) {
                    .petroraq-clients .hero-content h1 { font-size: 36px; }
                    .petroraq-clients .partnerships-grid { grid-template-columns: 1fr; }
                    .petroraq-clients .orgs-grid { grid-template-columns: repeat(2, 1fr); }
                    .petroraq-clients .why-grid { grid-template-columns: 1fr; }
                    .petroraq-clients .cta-banner { flex-direction: column; text-align: center; }
                    .petroraq-clients .cta-left { flex-direction: column; text-align: center; }
                    .petroraq-clients .cta-buttons { width: 100%; flex-direction: column; }
                    .petroraq-clients .btn-cta-primary,
                    .petroraq-clients .btn-cta-outline { justify-content: center; width: 100%; }
                    }
                </style>

                <div class="petroraq-clients">

                    <!-- ===== Hero Section ===== -->
                    <section class="clients-hero">
                        <div class="hero-overlay"></div>
                        <div class="hero-content">
                            <h1>Our Clients
                                <span class="dot">.</span>
                            </h1>
                            <p>Trusted by leading organizations across Saudi Arabia's industrial, infrastructure, and
                                development sectors.
                            </p>
                            <div class="hero-accent"></div>
                        </div>
                    </section>

                    <!-- ===== Partnerships Built on Trust ===== -->
                    <section class="partnerships-section">
                        <div class="pr-container">
                            <div class="partnerships-grid">
                                <div class="partnership-text">
                                    <h2>Partnerships Built on Trust</h2>
                                    <p>We are proud to collaborate with visionary organizations who share our commitment
                                        to excellence, safety, and sustainable development across the Kingdom.
                                    </p>
                                </div>

                                <div class="partnership-card">
                                    <div class="pc-icon">
                                        <i class="fa fa-users"></i>
                                    </div>
                                    <div class="pc-content">
                                        <h3>14+</h3>
                                        <h4>Key Clients</h4>
                                        <p>Across industrial, infrastructure, and development sectors.</p>
                                    </div>
                                </div>

                                <div class="partnership-card">
                                    <div class="pc-icon">
                                        <i class="fa fa-industry"></i>
                                    </div>
                                    <div class="pc-content">
                                        <h4 style="font-size: 14px; margin-bottom: 6px;">Industrial &amp;<br/>Mega
                                            Projects
                                        </h4>
                                        <p>Delivering complex, large-scale projects with proven expertise.</p>
                                    </div>
                                </div>

                                <div class="partnership-card">
                                    <div class="pc-icon">
                                        <i class="fa fa-handshake-o"></i>
                                    </div>
                                    <div class="pc-content">
                                        <h4 style="font-size: 14px; margin-bottom: 6px;">Trusted<br/>Partnerships
                                        </h4>
                                        <p>Long-term relationships built on performance and integrity.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ===== Organizations We Work With ===== -->
                    <section class="orgs-section">
                        <div class="pr-container">
                            <h2 class="section-title">Organizations We Work With</h2>
                            <div class="orgs-grid">
                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/en/thumb/2/2c/Saudi_Aramco_logo.svg/2560px-Saudi_Aramco_logo.svg.png"
                                         alt="Saudi Aramco"/>
                                </div>
                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/en/thumb/3/3a/Royal_Commission_for_AlUla_logo.svg/1200px-Royal_Commission_for_AlUla_logo.svg.png"
                                         alt="Royal Commission for Al-Ula"/>
                                </div>
                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/4/4e/NEOM_logo.svg/2560px-NEOM_logo.svg.png"
                                         alt="NEOM"/>
                                </div>
                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/en/thumb/1/1f/Saudi_Downtown_Company_logo.svg/1200px-Saudi_Downtown_Company_logo.svg.png"
                                         alt="Saudi Downtown Company"/>
                                </div>

                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/en/thumb/e/e3/Roshn_logo.svg/1200px-Roshn_logo.svg.png"
                                         alt="ROSHN"/>
                                </div>
                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/0/0a/Qiddiya_Logo.svg/2560px-Qiddiya_Logo.svg.png"
                                         alt="Qiddiya"/>
                                </div>
                                <div class="org-card">
                                    <img src="https://via.placeholder.com/200x80/ffffff/0a2540?text=Diriyah+Gate"
                                         alt="Diriyah Gate Development Authority"/>
                                </div>
                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/7/79/TAHAKOM_logo.svg/1200px-TAHAKOM_logo.svg.png"
                                         alt="TAHAKOM"/>
                                </div>

                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/0/0f/SEPCOIII_logo.svg/1200px-SEPCOIII_logo.svg.png"
                                         alt="SEPCO III"/>
                                </div>
                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e8/SABIC_Logo.svg/2560px-SABIC_Logo.svg.png"
                                         alt="SABIC"/>
                                </div>
                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/cb/Samsung_Engineering_logo.svg/2560px-Samsung_Engineering_logo.svg.png"
                                         alt="Samsung Engineering"/>
                                </div>
                                <div class="org-card">
                                    <img src="https://via.placeholder.com/200x80/ffffff/0a2540?text=Al+Bawani"
                                         alt="Al Bawani"/>
                                </div>

                                <div class="org-card">
                                    <img src="https://via.placeholder.com/200x80/ffffff/0a2540?text=NHC" alt="NHC"/>
                                </div>
                                <div class="org-card">
                                    <img src="https://upload.wikimedia.org/wikipedia/en/thumb/4/4e/Red_Sea_Global_logo.svg/1200px-Red_Sea_Global_logo.svg.png"
                                         alt="Red Sea Global"/>
                                </div>
                                <div class="org-card" style="border: none; background: transparent;"></div>
                                <div class="org-card" style="border: none; background: transparent;"></div>
                            </div>
                        </div>
                    </section>

                    <!-- ===== Why Leading Clients Choose PETRORAQ ===== -->
                    <section class="why-section">
                        <div class="pr-container">
                            <h2 class="section-title">Why Leading Clients Choose PETRORAQ</h2>
                            <div class="why-grid">
                                <div class="why-card">
                                    <div class="why-icon">
                                        <i class="fa fa-hard-hat"></i>
                                    </div>
                                    <h4>Engineering Excellence</h4>
                                    <p>Advanced engineering solutions delivered with precision and technical
                                        expertise.
                                    </p>
                                </div>
                                <div class="why-card">
                                    <div class="why-icon">
                                        <i class="fa fa-clipboard-list"></i>
                                    </div>
                                    <h4>Reliable Delivery</h4>
                                    <p>Proven track record of on-time delivery within scope, budget, and quality
                                        standards.
                                    </p>
                                </div>
                                <div class="why-card">
                                    <div class="why-icon">
                                        <i class="fa fa-shield"></i>
                                    </div>
                                    <h4>Quality &amp; Safety</h4>
                                    <p>Uncompromising commitment to quality, safety, and environmental responsibility.
                                    </p>
                                </div>
                                <div class="why-card">
                                    <div class="why-icon">
                                        <i class="fa fa-users"></i>
                                    </div>
                                    <h4>Long-Term Partnership</h4>
                                    <p>Building lasting relationships grounded in trust, transparency, and shared
                                        success.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ===== CTA Banner ===== -->
                    <section class="cta-section">
                        <div class="pr-container">
                            <div class="cta-banner">
                                <div class="cta-left">
                                    <div class="hex-icon">
                                        <i class="fa fa-building"></i>
                                    </div>
                                    <div class="cta-text">
                                        <h3>Building trusted partnerships for the future.</h3>
                                        <p>Let's create value, build excellence, and shape a better tomorrow.</p>
                                    </div>
                                </div>
                                <div class="cta-buttons">
                                    <a href="/contact-us" class="btn-cta-primary">
                                        Contact Us
                                        <i class="fa fa-arrow-right"></i>
                                    </a>
                                    <a href="#" class="btn-cta-outline">
                                        Explore Projects
                                        <i class="fa fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>
    </data>
</odoo>