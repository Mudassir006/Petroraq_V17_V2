<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="petroraq_about_us" name="PETRORAQ About Us" >
            <t t-call="website.layout">
                <t t-set="additional_title">About Us - PETRORAQ</t>

                <!-- Font Awesome &amp; Google Fonts -->
                <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
                <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>

                <style>
                    .petroraq-about * {
                        margin: 0;
                        padding: 0;
                        box-sizing: border-box;
                        font-family: 'Poppins', sans-serif;
                    }
                    .petroraq-about {
                        background: #ffffff;
                        color: #0a2540;
                    }
                    .petroraq-about .pr-container {
                        max-width: 1200px;
                        margin: 0 auto;
                        padding: 0 20px;
                    }

                    /* ===== Hero Section ===== */
                    .petroraq-about .about-hero {
                        position: relative;
                        min-height: 360px;
                        background: linear-gradient(135deg, #f0f2f5 0%, #e8ecf0 100%);
                        overflow: hidden;
                        display: flex;
                        align-items: center;
                    }
                    .petroraq-about .hero-wrap {
                        display: grid;
                        grid-template-columns: 1fr 1.2fr;
                        gap: 0;
                        width: 100%;
                        min-height: 360px;
                        align-items: stretch;
                    }
                    .petroraq-about .hero-left {
                        padding: 70px 60px;
                        display: flex;
                        flex-direction: column;
                        justify-content: center;
                    }
                    .petroraq-about .hero-left h1 {
                        font-size: 60px;
                        font-weight: 700;
                        color: #0a2540;
                        margin-bottom: 20px;
                        line-height: 1;
                    }
                    .petroraq-about .hero-left h1 .dot {
                        color: #d89a2b;
                    }
                    .petroraq-about .hero-left p {
                        font-size: 14px;
                        line-height: 1.7;
                        color: #4a5568;
                        max-width: 420px;
                        margin-bottom: 25px;
                    }
                    .petroraq-about .hero-accent {
                        width: 60px;
                        height: 3px;
                        background: #d89a2b;
                    }
                    .petroraq-about .hero-right {
                        background: url('https://images.unsplash.com/photo-1518709268805-4e9042af2176?w=1600&amp;q=80') center/cover no-repeat;
                        min-height: 360px;
                    }

                    /* ===== Section Padding ===== */
                    .petroraq-about .section {
                        padding: 60px 0;
                    }
                    .petroraq-about .section-title {
                        text-align: center;
                        font-size: 22px;
                        font-weight: 700;
                        color: #0a2540;
                        margin-bottom: 30px;
                        position: relative;
                        padding-bottom: 10px;
                    }
                    .petroraq-about .section-title::after {
                        content: '';
                        position: absolute;
                        left: 50%;
                        bottom: 0;
                        transform: translateX(-50%);
                        width: 50px;
                        height: 2px;
                        background: #d89a2b;
                    }

                    /* ===== Who We Are ===== */
                    .petroraq-about .who-section {
                        padding: 50px 0;
                    }
                    .petroraq-about .who-grid {
                        display: grid;
                        grid-template-columns: 1fr 2fr;
                        gap: 40px;
                        align-items: start;
                    }
                    .petroraq-about .who-text h2 {
                        font-size: 20px;
                        font-weight: 700;
                        color: #0a2540;
                        margin-bottom: 18px;
                    }
                    .petroraq-about .who-text p {
                        color: #6b7a8f;
                        font-size: 12.5px;
                        line-height: 1.8;
                        margin-bottom: 12px;
                    }
                    .petroraq-about .who-stats {
                        display: grid;
                        grid-template-columns: repeat(4, 1fr);
                        gap: 15px;
                    }
                    .petroraq-about .stat-card {
                        background: #fff;
                        border: 1px solid #e5e8ec;
                        border-radius: 10px;
                        padding: 25px 15px;
                        text-align: center;
                        transition: transform 0.3s, box-shadow 0.3s;
                    }
                    .petroraq-about .stat-card:hover {
                        transform: translateY(-4px);
                        box-shadow: 0 8px 20px rgba(0,0,0,0.06);
                    }
                    .petroraq-about .stat-card i {
                        font-size: 32px;
                        color: #d89a2b;
                        margin-bottom: 12px;
                    }
                    .petroraq-about .stat-card h3 {
                        font-size: 16px;
                        font-weight: 700;
                        color: #0a2540;
                        margin-bottom: 6px;
                        line-height: 1.3;
                    }
                    .petroraq-about .stat-card p {
                        font-size: 11px;
                        color: #6b7a8f;
                        line-height: 1.5;
                    }

                    /* ===== Mission / Vision ===== */
                    .petroraq-about .mv-section {
                        padding: 20px 0 50px;
                    }
                    .petroraq-about .mv-grid {
                        display: grid;
                        grid-template-columns: 1fr 1fr;
                        gap: 20px;
                    }
                    .petroraq-about .mv-card {
                        background: #fff;
                        border: 1px solid #e5e8ec;
                        border-left: 4px solid #d89a2b;
                        border-radius: 10px;
                        padding: 30px;
                        display: flex;
                        gap: 22px;
                        align-items: flex-start;
                    }
                    .petroraq-about .mv-icon {
                        width: 75px;
                        height: 75px;
                        background: #fff;
                        border: 2px solid #d89a2b;
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        flex-shrink: 0;
                    }
                    .petroraq-about .mv-icon i {
                        color: #d89a2b;
                        font-size: 28px;
                    }
                    .petroraq-about .mv-text h3 {
                        font-size: 19px;
                        font-weight: 700;
                        color: #0a2540;
                        margin-bottom: 10px;
                    }
                    .petroraq-about .mv-text p {
                        font-size: 12.5px;
                        color: #6b7a8f;
                        line-height: 1.7;
                    }

                    /* ===== Core Values ===== */
                    .petroraq-about .values-section {
                        padding: 40px 0;
                    }
                    .petroraq-about .values-grid {
                        display: grid;
                        grid-template-columns: repeat(6, 1fr);
                        gap: 15px;
                    }
                    .petroraq-about .value-card {
                        background: #fff;
                        border: 1px solid #e5e8ec;
                        border-radius: 10px;
                        padding: 25px 15px;
                        text-align: center;
                        transition: transform 0.3s, box-shadow 0.3s;
                    }
                    .petroraq-about .value-card:hover {
                        transform: translateY(-4px);
                        box-shadow: 0 8px 20px rgba(0,0,0,0.06);
                    }
                    .petroraq-about .value-card i {
                        font-size: 30px;
                        color: #d89a2b;
                        margin-bottom: 12px;
                    }
                    .petroraq-about .value-card h4 {
                        font-size: 13px;
                        font-weight: 700;
                        color: #0a2540;
                        margin-bottom: 8px;
                    }
                    .petroraq-about .value-card p {
                        font-size: 10.5px;
                        color: #6b7a8f;
                        line-height: 1.5;
                    }

                    /* ===== Our Expertise ===== */
                    .petroraq-about .expertise-section {
                        padding: 40px 0;
                    }
                    .petroraq-about .expertise-grid {
                        display: grid;
                        grid-template-columns: repeat(5, 1fr);
                        gap: 15px;
                        margin-bottom: 15px;
                    }
                    .petroraq-about .expertise-grid-4 {
                        display: grid;
                        grid-template-columns: repeat(4, 1fr);
                        gap: 15px;
                        max-width: 85%;
                        margin: 0 auto;
                    }
                    .petroraq-about .expertise-card {
                        background: #fff;
                        border: 1px solid #e5e8ec;
                        border-radius: 10px;
                        padding: 28px 15px;
                        text-align: center;
                        transition: transform 0.3s, box-shadow 0.3s;
                        min-height: 130px;
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        justify-content: center;
                        gap: 10px;
                    }
                    .petroraq-about .expertise-card:hover {
                        transform: translateY(-4px);
                        box-shadow: 0 8px 20px rgba(0,0,0,0.06);
                        border-color: #d89a2b;
                    }
                    .petroraq-about .expertise-card i {
                        font-size: 32px;
                        color: #d89a2b;
                    }
                    .petroraq-about .expertise-card p {
                        font-size: 12px;
                        font-weight: 600;
                        color: #0a2540;
                        line-height: 1.3;
                    }

                    /* ===== Certifications ===== */
                    .petroraq-about .certs-section {
                        padding: 40px 0 60px;
                    }
                    .petroraq-about .certs-grid {
                        display: grid;
                        grid-template-columns: repeat(5, 1fr);
                        gap: 15px;
                    }
                    .petroraq-about .cert-card {
                        background: #fff;
                        border: 1px solid #e5e8ec;
                        border-radius: 10px;
                        padding: 25px 18px;
                        text-align: center;
                        transition: transform 0.3s;
                    }
                    .petroraq-about .cert-card:hover {
                        transform: translateY(-3px);
                        box-shadow: 0 8px 18px rgba(0,0,0,0.05);
                    }
                    .petroraq-about .cert-icon {
                        font-size: 36px;
                        color: #d89a2b;
                        margin-bottom: 12px;
                    }
                    .petroraq-about .cert-iso {
                        font-size: 28px;
                        font-weight: 800;
                        color: #d89a2b;
                        margin-bottom: 8px;
                        letter-spacing: 1px;
                    }
                    .petroraq-about .cert-card h4 {
                        font-size: 14px;
                        font-weight: 700;
                        color: #0a2540;
                        margin-bottom: 10px;
                    }
                    .petroraq-about .cert-card p {
                        font-size: 11px;
                        color: #6b7a8f;
                        line-height: 1.5;
                    }

                    /* ===== CTA Banner ===== */
                    .petroraq-about .cta-section {
                        padding: 30px 0 50px;
                    }
                    .petroraq-about .cta-banner {
                        background: #0a2540;
                        background-image:
                            radial-gradient(circle at 90% 50%, rgba(216,154,43,0.08) 0%, transparent 50%),
                            linear-gradient(135deg, #0a2540 0%, #071a2f 100%);
                        border: 1px solid rgba(216,154,43,0.25);
                        border-radius: 12px;
                        padding: 30px 40px;
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        flex-wrap: wrap;
                        gap: 25px;
                    }
                    .petroraq-about .cta-left {
                        display: flex;
                        align-items: center;
                        gap: 22px;
                    }
                    .petroraq-about .hex-icon {
                        width: 60px;
                        height: 60px;
                        background: transparent;
                        border: 2px solid #d89a2b;
                        clip-path: polygon(25% 5%, 75% 5%, 100% 50%, 75% 95%, 25% 95%, 0% 50%);
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        flex-shrink: 0;
                    }
                    .petroraq-about .hex-icon i {
                        color: #d89a2b;
                        font-size: 22px;
                    }
                    .petroraq-about .cta-text h3 {
                        color: #fff;
                        font-size: 22px;
                        font-weight: 700;
                        margin-bottom: 4px;
                    }
                    .petroraq-about .cta-text p {
                        color: #b8c5d6;
                        font-size: 13px;
                    }
                    .petroraq-about .cta-buttons {
                        display: flex;
                        gap: 12px;
                    }
                    .petroraq-about .btn-cta-primary,
                    .petroraq-about .btn-cta-outline {
                        padding: 13px 28px;
                        border-radius: 6px;
                        font-size: 13px;
                        font-weight: 600;
                        text-decoration: none;
                        display: inline-flex;
                        align-items: center;
                        gap: 10px;
                        transition: all 0.3s;
                    }
                    .petroraq-about .btn-cta-primary {
                        background: #d89a2b;
                        color: #fff;
                    }
                    .petroraq-about .btn-cta-primary:hover {
                        background: #e5a838;
                        color: #fff;
                        transform: translateY(-2px);
                    }
                    .petroraq-about .btn-cta-outline {
                        background: transparent;
                        color: #fff;
                        border: 1px solid rgba(255,255,255,0.3);
                    }
                    .petroraq-about .btn-cta-outline:hover {
                        background: rgba(255,255,255,0.08);
                        color: #fff;
                    }

                    /* ===== Responsive ===== */
                    @media (max-width: 992px) {
                        .petroraq-about .hero-wrap { grid-template-columns: 1fr; }
                        .petroraq-about .hero-right { min-height: 250px; }
                        .petroraq-about .hero-left { padding: 50px 30px; }
                        .petroraq-about .hero-left h1 { font-size: 48px; }
                        .petroraq-about .who-grid { grid-template-columns: 1fr; }
                        .petroraq-about .who-stats { grid-template-columns: repeat(2, 1fr); }
                        .petroraq-about .mv-grid { grid-template-columns: 1fr; }
                        .petroraq-about .values-grid { grid-template-columns: repeat(3, 1fr); }
                        .petroraq-about .expertise-grid { grid-template-columns: repeat(3, 1fr); }
                        .petroraq-about .expertise-grid-4 { grid-template-columns: repeat(2, 1fr); max-width: 100%; }
                        .petroraq-about .certs-grid { grid-template-columns: repeat(2, 1fr); }
                    }
                    @media (max-width: 600px) {
                        .petroraq-about .hero-left h1 { font-size: 38px; }
                        .petroraq-about .values-grid { grid-template-columns: repeat(2, 1fr); }
                        .petroraq-about .expertise-grid { grid-template-columns: repeat(2, 1fr); }
                        .petroraq-about .certs-grid { grid-template-columns: 1fr; }
                        .petroraq-about .cta-banner { flex-direction: column; text-align: center; }
                        .petroraq-about .cta-left { flex-direction: column; text-align: center; }
                        .petroraq-about .cta-buttons { width: 100%; flex-direction: column; }
                        .petroraq-about .btn-cta-primary,
                        .petroraq-about .btn-cta-outline { justify-content: center; width: 100%; }
                    }
                </style>

                <div class="petroraq-about">

                    <!-- ===== Hero Section ===== -->
                    <section class="about-hero">
                        <div class="hero-wrap">
                            <div class="hero-left">
                                <h1>About Us<span class="dot">.</span></h1>
                                <p>PETRORAQ is a multidisciplinary engineering, procurement, construction, and project management company delivering excellence across Saudi Arabia and the GCC.</p>
                                <div class="hero-accent"></div>
                            </div>
                            <div class="hero-right"></div>
                        </div>
                    </section>

                    <!-- ===== Who We Are ===== -->
                    <section class="who-section">
                        <div class="pr-container">
                            <div class="who-grid">
                                <div class="who-text">
                                    <h2>Who We Are</h2>
                                    <p>PETRORAQ is an international multidisciplinary engineering and construction organization offering comprehensive solutions in engineering consultancy, procurement, construction, and project management.</p>
                                    <p>We deliver infrastructure planning and development across residential, commercial, industrial, and environmental sectors, with expertise in mechanical, electrical, piping, telecommunication, BIM, and related disciplines.</p>
                                    <p>With a skilled workforce and a commitment to excellence, we help our clients build a stronger, more sustainable future.</p>
                                </div>
                                <div class="who-stats">
                                    <div class="stat-card">
                                        <i class="fa fa-users"></i>
                                        <h3>Multidisciplinary<br/>Expertise</h3>
                                        <p>End-to-end solutions across all engineering and construction disciplines.</p>
                                    </div>
                                    <div class="stat-card">
                                        <i class="fa fa-users"></i>
                                        <h3>801+<br/><span style="font-weight: 500; font-size: 13px;">Workforce</span></h3>
                                        <p>Skilled professionals driving projects with excellence and integrity.</p>
                                    </div>
                                    <div class="stat-card">
                                        <i class="fa fa-map-marker"></i>
                                        <h3>Saudi Arabia<br/>&amp; GCC</h3>
                                        <p>Delivering projects across Saudi Arabia and the GCC region.</p>
                                    </div>
                                    <div class="stat-card">
                                        <i class="fa fa-shield"></i>
                                        <h3>ISO<br/>Certified</h3>
                                        <p>Committed to international standards in quality, safety and environment.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ===== Mission &amp; Vision ===== -->
                    <section class="mv-section">
                        <div class="pr-container">
                            <div class="mv-grid">
                                <div class="mv-card">
                                    <div class="mv-icon"><i class="fa fa-bullseye"></i></div>
                                    <div class="mv-text">
                                        <h3>Our Mission</h3>
                                        <p>To deliver world-class engineering and construction solutions built on innovation, quality, and client satisfaction while fostering long-term partnerships grounded in trust and excellence.</p>
                                    </div>
                                </div>
                                <div class="mv-card">
                                    <div class="mv-icon"><i class="fa fa-eye"></i></div>
                                    <div class="mv-text">
                                        <h3>Our Vision</h3>
                                        <p>To be a global leader in engineering and construction, recognized for our quality, innovation, and commitment to sustainable development.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ===== Core Values ===== -->
                    <section class="values-section">
                        <div class="pr-container">
                            <h2 class="section-title">Our Core Values</h2>
                            <div class="values-grid">
                                <div class="value-card">
                                    <i class="fa fa-shield"></i>
                                    <h4>Integrity</h4>
                                    <p>We act with honesty, transparency and ethical responsibility.</p>
                                </div>
                                <div class="value-card">
                                    <i class="fa fa-star"></i>
                                    <h4>Excellence</h4>
                                    <p>We strive for the highest standards in everything we do.</p>
                                </div>
                                <div class="value-card">
                                    <i class="fa fa-lightbulb"></i>
                                    <h4>Innovation</h4>
                                    <p>We embrace new ideas and technologies to create better solutions.</p>
                                </div>
                                <div class="value-card">
                                    <i class="fa fa-users"></i>
                                    <h4>Collaboration</h4>
                                    <p>We believe in teamwork and strong partnerships to achieve success.</p>
                                </div>
                                <div class="value-card">
                                    <i class="fa fa-leaf"></i>
                                    <h4>Sustainability</h4>
                                    <p>We are committed to building a better future for generations to come.</p>
                                </div>
                                <div class="value-card">
                                    <i class="fa fa-wrench"></i>
                                    <h4>Safety</h4>
                                    <p>We prioritize the health and safety of our people and communities.</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ===== Our Expertise ===== -->
                    <section class="expertise-section">
                        <div class="pr-container">
                            <h2 class="section-title">Our Expertise</h2>
                            <div class="expertise-grid">
                                <div class="expertise-card">
                                    <i class="fa fa-pencil-square-o"></i>
                                    <p>Engineering &amp; Design</p>
                                </div>
                                <div class="expertise-card">
                                    <i class="fa fa-shopping-cart"></i>
                                    <p>Procurement</p>
                                </div>
                                <div class="expertise-card">
                                    <i class="fa fa-wrench"></i>
                                    <p>Construction</p>
                                </div>
                                <div class="expertise-card">
                                    <i class="fa fa-list-alt"></i>
                                    <p>Project Management</p>
                                </div>
                                <div class="expertise-card">
                                    <i class="fa fa-road"></i>
                                    <p>Infrastructure &amp; Civil Projects</p>
                                </div>
                            </div>
                            <div class="expertise-grid-4">
                                <div class="expertise-card">
                                    <i class="fa fa-bolt"></i>
                                    <p>MEP Contracting</p>
                                </div>
                                <div class="expertise-card">
                                    <i class="fa fa-cogs"></i>
                                    <p>Industrial Equipment Procurement &amp; Installation</p>
                                </div>
                                <div class="expertise-card">
                                    <i class="fa fa-chart-line"></i>
                                    <p>Value Engineering</p>
                                </div>
                                <div class="expertise-card">
                                    <i class="fa fa-building"></i>
                                    <p>Design &amp; Build Contracting</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ===== Quality, HSE &amp; Certifications ===== -->
                    <section class="certs-section">
                        <div class="pr-container">
                            <h2 class="section-title">Quality, HSE &amp; Certifications</h2>
                            <div class="certs-grid">
                                <div class="cert-card">
                                    <div class="cert-icon"><i class="fa fa-trophy"></i></div>
                                    <h4>QA/QC</h4>
                                    <p>Robust quality assurance and control processes ensuring consistent project excellence.</p>
                                </div>
                                <div class="cert-card">
                                    <div class="cert-icon"><i class="fa fa-shield"></i></div>
                                    <h4>HSE</h4>
                                    <p>Comprehensive Health, Safety &amp; Environment programs for a safe and responsible workplace.</p>
                                </div>
                                <div class="cert-card">
                                    <div class="cert-iso">ISO</div>
                                    <h4>ISO 9001:2015</h4>
                                    <p>Quality Management System for delivering consistent quality and client satisfaction.</p>
                                </div>
                                <div class="cert-card">
                                    <div class="cert-iso">ISO</div>
                                    <h4>ISO 14001:2015</h4>
                                    <p>Environmental Management System for sustainable operations and reduced environmental impact.</p>
                                </div>
                                <div class="cert-card">
                                    <div class="cert-iso">ISO</div>
                                    <h4>ISO 45001:2018</h4>
                                    <p>Occupational Health &amp; Safety Management System for protecting our people and promoting well-being.</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ===== CTA Banner ===== -->
                    <section class="cta-section">
                        <div class="pr-container">
                            <div class="cta-banner">
                                <div class="cta-left">
                                    <div class="hex-icon">
                                        <i class="fa fa-building"></i>
                                    </div>
                                    <div class="cta-text">
                                        <h3>Building the Future, Together.</h3>
                                        <p>Let's create value, build excellence, and shape a better tomorrow.</p>
                                    </div>
                                </div>
                                <div class="cta-buttons">
                                    <a href="/contact-us" class="btn-cta-primary">
                                        Contact Us <i class="fa fa-arrow-right"></i>
                                    </a>
                                    <a href="/projects" class="btn-cta-outline">
                                        Explore Our Projects <i class="fa fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>
    </data>
</odoo>