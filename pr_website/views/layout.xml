<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="petroraq_layout" inherit_id="website.layout">
            <xpath expr="//head" position="inside">
                <link rel="stylesheet"
                      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
                <style>
                    * { box-sizing: border-box; margin: 0; padding: 0; }
                    body { font-family: 'Arial', sans-serif; color: #222; background: #fff; }
                    a { text-decoration: none; color: inherit; }
                    ul { list-style: none; }
                    img { max-width: 100%; display: block; }

                    /* ===== Navbar ===== */
                    .navbar {
                    background-color: #06264B;
                    display: flex;
                    align-items: center;
                    padding: 15px 40px;
                    position: relative;
                    z-index: 100;
                    gap: 30px;
                    }
                    .navbar-logo { flex-shrink: 0; }
                    .navbar-logo img { height: 55px; }
                    .navbar-links {
                    display: flex;
                    align-items: center;
                    gap: 35px;
                    flex: 1;
                    justify-content: center;
                    }
                    .navbar-links a {
                    color: #fff;
                    font-size: 15px;
                    font-weight: 400;
                    padding: 6px 2px;
                    position: relative;
                    transition: color 0.3s;
                    }
                    .navbar-links a.active { color: #e9a23e; }
                    .navbar-links a.active::after {
                    content: "";
                    position: absolute;
                    bottom: -4px;
                    left: 0;
                    width: 100%;
                    height: 2px;
                    background: #e9a23e;
                    }
                    .navbar-links a:hover { color: #e9a23e; }
                    .quote-btn {
                    background-color: #e9a23e;
                    border: none;
                    color: #fff;
                    padding: 12px 24px;
                    border-radius: 6px;
                    font-size: 14px;
                    font-weight: 600;
                    cursor: pointer;
                    display: inline-flex;
                    align-items: center;
                    gap: 10px;
                    transition: background 0.3s;
                    flex-shrink: 0;
                    text-decoration: none;
                    }
                    .quote-btn:hover { background-color: #cc8e34; color: #fff; }
                    .navbar-toggle {
                    display: none;
                    background: none;
                    border: none;
                    color: #fff;
                    font-size: 24px;
                    cursor: pointer;
                    }
                    @media (max-width: 992px) {
                    .navbar { padding: 15px 20px; }
                    .navbar-toggle { display: block; margin-left: auto; }
                    .navbar-links {
                    position: absolute;
                    top: 85px;
                    left: 0;
                    right: 0;
                    background: #06264B;
                    flex-direction: column;
                    align-items: flex-start;
                    padding: 20px;
                    gap: 15px;
                    max-height: 0;
                    overflow: hidden;
                    transition: max-height 0.3s ease;
                    border-bottom: 3px solid #e9a23e;
                    justify-content: flex-start;
                    }
                    .navbar-links.open { max-height: 600px; }
                    .navbar-links a { width: 100%; }
                    .quote-btn { display: none; }
                    }
                </style>
            </xpath>

            <xpath expr="//header" position="replace">
                <header class="o_not_editable">
                    <nav class="navbar">
                        <div class="navbar-logo">
                            <a href="/">
                                <img src="/pr_website/static/images/logo.png" alt="PETRORAQ Logo"/>
                            </a>
                        </div>
                        <button class="navbar-toggle" aria-label="Toggle menu" type="button">
                            <i class="fa fa-bars"></i>
                        </button>
                        <div class="navbar-links" id="navLinks">
                            <a href="/" t-att-class="'active' if request.httprequest.path == '/' else ''">Home</a>
                            <a href="/about-us"
                               t-att-class="'active' if request.httprequest.path.startswith('/about') else ''">About
                            </a>
                            <a href="#"
                               t-att-class="'active' if request.httprequest.path.startswith('/services') else ''">
                                Services
                            </a>
                            <a href="#"
                               t-att-class="'active' if request.httprequest.path.startswith('/projects') else ''">
                                Projects
                            </a>
                            <a href="/clients"
                               t-att-class="'active' if request.httprequest.path.startswith('/clients') else ''">Clients
                            </a>
                            <a href="/jobs"
                               t-att-class="'active' if (request.httprequest.path.startswith('/jobs') or request.httprequest.path.startswith('/careers') or request.httprequest.path.startswith('/job/')) else ''">
                                Careers
                            </a>
                            <a href="/contact-us"
                               t-att-class="'active' if request.httprequest.path.startswith('/contact') else ''">Contact Us
                            </a>
                        </div>
                        <a href="/contact-us" class="quote-btn">
                            Request a Quote
                            <i class="fa fa-arrow-right"></i>
                        </a>
                    </nav>
                </header>
            </xpath>

            <xpath expr="//body" position="inside">
                <script>
                    (function () {
                    var toggleBtn = document.querySelector('.navbar-toggle');
                    var navLinks = document.getElementById('navLinks');
                    if (toggleBtn &amp;&amp; navLinks) {
                    toggleBtn.addEventListener('click', function () {
                    navLinks.classList.toggle('open');
                    });
                    }
                    })();
                </script>
            </xpath>
        </template>
    </data>
</odoo>