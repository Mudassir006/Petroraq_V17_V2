<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="petroraq_layout" inherit_id="website.layout">

        <xpath expr="//head" position="inside">
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
            <style>
                * { box-sizing: border-box; }
                body { margin: 0; font-family: 'Arial', sans-serif; }
                .navbar {
                background-color: #022851;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 20px;
                height: 60px;
                }
                .navbar-logo {
                width: 160px;
                height: 40px;
                background-color: transparent;
                display: flex;
                align-items: center;
                }
                .navbar-links {
                display: flex;
                align-items: center;
                gap: 28px;
                }
                .navbar-links a {
                color: #ffffff;
                text-decoration: none;
                font-weight: 500;
                padding: 10px 6px;
                font-size: 14px;
                transition: color 0.3s ease;
                }
                .navbar-links a:hover, .navbar-links a.active { color: #e9a23e; }
                .quote-btn {
                background-color: #e9a23e;
                border: none;
                padding: 10px 22px;
                border-radius: 4px;
                color: #fff;
                font-weight: 600;
                cursor: pointer;
                font-size: 14px;
                display: flex;
                align-items: center;
                gap: 6px;
                transition: background-color 0.3s ease;
                }
                .quote-btn:hover { background-color: #cc8e34; }
                .quote-btn i { font-size: 16px; }
                .navbar-toggle {
                display: none;
                font-size: 22px;
                color: white;
                cursor: pointer;
                background: none;
                border: none;
                }
                @media (max-width: 768px) {
                .navbar-links {
                position: absolute;
                top: 60px;
                left: 0;
                right: 0;
                background-color: #022851;
                flex-direction: column;
                align-items: flex-start;
                padding: 10px 20px;
                gap: 12px;
                max-height: 0;
                overflow: hidden;
                transition: max-height 0.3s ease;
                z-index: 999;
                border-bottom: 3px solid #e9a23e;
                }
                .navbar-links.open { max-height: 300px; }
                .quote-btn { width: 100%; justify-content: center; }
                .navbar-toggle { display: block; }
                .navbar-links a { width: 100%; padding: 10px 0; font-size: 16px; }
                }
            </style>
        </xpath>

        <xpath expr="//header" position="replace">
            <header class="o_not_editable">
                <nav class="navbar">
                    <div class="navbar-logo" aria-label="Pertoraq Logo">
                        <img src="/pr_website/static/images/logo.png" alt="Pertoraq Logo" style="height:40px; width:160px; object-fit:contain;"/>
                    </div>

                    <button class="navbar-toggle" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="nav-menu" type="button">
                        <i class="fas fa-bars"></i>
                    </button>

                    <div class="navbar-links" id="nav-menu">
                        <a href="#" class="active">Home</a>
                        <a href="#">About</a>
                        <a href="#">Services</a>
                        <a href="#">Projects</a>
                        <a href="#">Certifications</a>
                        <a href="#">Contact</a>
                        <button class="quote-btn" type="button">
                            Request a Quote <i class="fas fa-arrow-right"></i>
                        </button>
                    </div>
                </nav>
            </header>
        </xpath>

        <xpath expr="//body" position="inside">
            <script>
                document.addEventListener('DOMContentLoaded', function () {
                const toggleButton = document.querySelector('.navbar-toggle');
                const navLinks = document.querySelector('.navbar-links');
                if (toggleButton &amp;&amp; navLinks) {
                toggleButton.addEventListener('click', () =&gt; {
                const expanded = toggleButton.getAttribute('aria-expanded') === 'true' || false;
                toggleButton.setAttribute('aria-expanded', (!expanded).toString());
                navLinks.classList.toggle('open');
                });
                }
                });
            </script>
        </xpath>

    </template>
</odoo>
